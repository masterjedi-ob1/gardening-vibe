# Supabase — copy to .env.local and fill in from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Used server-side only (migrations, seed scripts)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — for the AI Green Thumb coach
ANTHROPIC_API_KEY=your-anthropic-api-key

# Vision — plant diagnosis. Qwen2.5-VL is the priority model; Claude Haiku vision
# is the automatic fallback (only used if no Qwen provider is set or a call fails).
# Routing (first match wins):
#   1. VISION_ENDPOINT_URL          → Andrew Brown's bespoke endpoint ({image,context})
#   2. an OpenAI-compatible provider → VISION_PROVIDER preset OR VISION_API_URL
#   3. neither                      → Claude Haiku vision fallback
#
# --- Option A: a provider key (Hyperbolic / Together / Novita / OpenRouter / HF) ---
# Pick a preset and supply its key + the model id that provider serves.
#   VISION_PROVIDER=hyperbolic   → https://api.hyperbolic.xyz/v1/chat/completions
#   VISION_PROVIDER=together     → https://api.together.xyz/v1/chat/completions
#   VISION_PROVIDER=novita       → https://api.novita.ai/v3/openai/chat/completions
#   VISION_PROVIDER=openrouter   → https://openrouter.ai/api/v1/chat/completions
#   VISION_PROVIDER=huggingface  → https://router.huggingface.co/v1/chat/completions
VISION_PROVIDER=
VISION_API_KEY=
# Model id AS THAT PROVIDER LISTS IT (e.g. Hyperbolic: Qwen/Qwen2.5-VL-7B-Instruct;
# Together/Novita often only host the 72B: Qwen/Qwen2.5-VL-72B-Instruct).
VISION_MODEL=
# Or skip the preset and give the chat-completions URL directly:
VISION_API_URL=

# --- Option B: Andrew Brown's bespoke endpoint ({image, context} body) ---
VISION_ENDPOINT_URL=
VISION_ENDPOINT_TOKEN=

# Legacy aliases (still honoured): HF_TOKEN, VISION_HF_URL
HF_TOKEN=
VISION_HF_URL=

# NotebookLM — garden knowledge base notebook ID (from scripts/setup-notebooklm.sh).
# Requires `notebooklm login` (browser OAuth) on the machine running the app, OR
# NOTEBOOKLM_AUTH_JSON containing exported auth credentials for headless/serverless use.
NOTEBOOKLM_NOTEBOOK_ID=
NOTEBOOKLM_AUTH_JSON=
