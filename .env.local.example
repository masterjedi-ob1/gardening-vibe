# Supabase — copy to .env.local and fill in from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Used server-side only (migrations, seed scripts)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — for the AI Green Thumb coach
ANTHROPIC_API_KEY=your-anthropic-api-key

# Vision — Qwen2.5-VL endpoint (Andrew Brown's host); leave blank to use Claude Haiku vision fallback
VISION_ENDPOINT_URL=
VISION_ENDPOINT_TOKEN=

# NotebookLM — garden knowledge base notebook ID (from scripts/setup-notebooklm.sh)
NOTEBOOKLM_NOTEBOOK_ID=
