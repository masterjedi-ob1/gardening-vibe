# Supabase — copy to .env.local and fill in from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Used server-side only (migrations, seed scripts)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — for the AI Green Thumb coach
ANTHROPIC_API_KEY=your-anthropic-api-key

# Vision — plant diagnosis. Routing (first match wins):
#   1. VISION_ENDPOINT_URL set      → Andrew Brown's custom Qwen2.5-VL endpoint
#   2. VISION_PROVIDER=huggingface  → HuggingFace Inference API (Qwen2.5-VL)
#   3. neither                      → Claude Haiku vision fallback (always works)
VISION_ENDPOINT_URL=
VISION_ENDPOINT_TOKEN=
# Set VISION_PROVIDER=huggingface to use HF Inference API instead of a custom endpoint.
VISION_PROVIDER=
# HF token (or reuse VISION_ENDPOINT_TOKEN). Defaults: model Qwen/Qwen2.5-VL-7B-Instruct via the HF router.
HF_TOKEN=
VISION_MODEL=
VISION_HF_URL=

# NotebookLM — garden knowledge base notebook ID (from scripts/setup-notebooklm.sh).
# Requires `notebooklm login` (browser OAuth) on the machine running the app, OR
# NOTEBOOKLM_AUTH_JSON containing exported auth credentials for headless/serverless use.
NOTEBOOKLM_NOTEBOOK_ID=
NOTEBOOKLM_AUTH_JSON=
